# Workforce Management System - Environment Configuration

# SendGrid Email Configuration
REACT_APP_SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
REACT_APP_FROM_EMAIL=noreply@yourcompany.com
REACT_APP_FROM_NAME=Your Company Name

# Frontend URL (your React app)
REACT_APP_FRONTEND_URL=http://localhost:3000

# Backend API (your Render server)
REACT_APP_API_BASE_URL=https://fieldsync-backend.onrender.com/api
# SendGrid Setup Instructions:
# 1. Sign up for a SendGrid account at https://sendgrid.com
# 2. Verify your sender email/domain in SendGrid Dashboard
# 3. Create an API key with "Mail Send" permissions
# 4. Copy the API key and add it to REACT_APP_SENDGRID_API_KEY
# 5. Configure your from email address in REACT_APP_FROM_EMAIL
# 6. Set your company name in REACT_APP_FROM_NAME

# Example API Key Format:
# REACT_APP_SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Security Notes:
# - Never commit API keys to version control
# - Use environment variables in production
# - Restrict API key permissions to minimum required
# - Monitor API usage in SendGrid dashboard
